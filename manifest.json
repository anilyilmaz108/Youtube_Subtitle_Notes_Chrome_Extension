{
  "manifest_version": 3,
  "name": "YouTube Subtitle Notes",
  "version": "1.0.0",
  "description": "Save YouTube subtitles as notes, translate English subtitles into Turkish, and download them.",
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Subtitle Notes"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-extractor.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}
